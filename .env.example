# --- Identifiants INPI (compte data.inpi.fr) ---
# Utilisés pour l'API RNE (Registre National des Entreprises).
INPI_USERNAME=votre_email@example.com
INPI_PASSWORD=votre_mot_de_passe

# --- Identifiants API PI Marques (OPTIONNEL) ---
# L'API "Données Marques" (api-gateway.inpi.fr) s'appuie sur un COMPTE TECHNIQUE
# distinct, créé lors de l'activation de l'accès "APIs PI" sur data.inpi.fr.
# Si ces variables sont absentes, le serveur réutilise INPI_USERNAME/INPI_PASSWORD.
# INPI_PI_USERNAME=compte_technique@example.com
# INPI_PI_PASSWORD=mot_de_passe_technique

# --- Sécurité : authentification de l'endpoint MCP ---
# Clé d'API protégeant le serveur. Les clients doivent envoyer le header
#   Authorization: Bearer <MCP_API_KEY>
# sur /sse et /messages/ (le endpoint /health reste ouvert pour le healthcheck).
# Si cette variable est absente/vide, l'endpoint MCP est PUBLIC (déconseillé).
# Générez votre propre clé, par ex. :  python -c "import secrets; print('mcpinpi_' + secrets.token_urlsafe(32))"
MCP_API_KEY=mcpinpi_AZMOPkRg3Uk9SrLRZlkvDTik8kCy7a-xuoqCpXGSNzA

# --- Réseau ---
# Port d'écoute du serveur SSE. Sur Railway, PORT est injecté automatiquement.
PORT=8080
HOST=0.0.0.0
